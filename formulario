<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal Escolar - EEB Dom Jaime</title>
    <style>
        :root {
            --azul-institucional: #0a3d62;
            --azul-fundo: #e1eaf0;
            --branco: #ffffff;
            --sucesso: #27ae60;
            --detalhe-escola: #f39c12;
            /* Cor de destaque para detalhes escolares */
            --sombra: 0 4px 15px rgba(0, 0, 0, 0.1);
            --transicao: all 0.3s ease;
        }

        body {
            background-color: var(--azul-fundo);
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            color: #2c3e50;
        }

        /* Menu de Navegação */
        .menu {
            background-color: var(--azul-institucional);
            color: white;
            padding: 0 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 80px;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-weight: bold;
            font-size: 1.4rem;
            letter-spacing: 1px;
            border-left: 4px solid var(--detalhe-escola);
            padding-left: 15px;
        }

        .menu-centro span {
            margin: 0 8px;
            padding: 12px 18px;
            cursor: pointer;
            border-radius: 5px;
            transition: var(--transicao);
            font-weight: 500;
        }

        .menu-centro span:hover {
            background-color: rgba(255, 255, 255, 0.1);
            color: var(--detalhe-escola);
        }

        /* Cabeçalho */
        .titulo-principal {
            text-align: center;
            padding: 40px 20px;
            background: var(--branco);
            margin-bottom: 20px;
            border-bottom: 5px solid var(--azul-institucional);
        }

        .titulo-principal h1 {
            margin: 0;
            color: var(--azul-institucional);
            font-size: 2.2rem;
        }

        /* Cards e Conteúdo */
        .card {
            background-color: var(--branco);
            width: 90%;
            max-width: 700px;
            padding: 40px;
            border-radius: 12px;
            margin: 20px auto;
            box-shadow: var(--sombra);
            display: none;
            border-top: 8px solid var(--azul-institucional);
        }

        .pagina-ativa {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Estilos do Início (Dashboard) */
        .grid-dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-top: 25px;
        }

        .item-dash {
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            padding: 25px;
            border-radius: 10px;
            text-align: center;
            transition: var(--transicao);
        }

        .item-dash:hover {
            border-color: var(--azul-institucional);
            transform: scale(1.03);
        }

        .item-dash h3 {
            color: var(--azul-institucional);
            font-size: 1rem;
            margin-bottom: 10px;
        }

        .item-dash p {
            font-size: 2.5rem;
            margin: 0;
            font-weight: bold;
            color: var(--detalhe-escola);
        }

        /* Formulários */
        label {
            font-weight: bold;
            margin-bottom: 8px;
            display: block;
            color: var(--azul-institucional);
        }

        input,
        select {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 6px;
            box-sizing: border-box;
            font-size: 1rem;
        }

        .btn-cadastrar {
            background-color: var(--azul-institucional);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 6px;
            cursor: pointer;
            width: 100%;
            font-weight: bold;
            font-size: 1.1rem;
            transition: var(--transicao);
        }

        .btn-cadastrar:hover {
            background-color: #082d49;
        }

        /* Rodapé e Redes Sociais */
        footer {
            margin-top: auto;
            background-color: var(--azul-institucional);
            color: white;
            text-align: center;
            padding: 30px;
        }

        .redes-sociais {
            margin-top: 15px;
        }

        .redes-sociais a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
            padding: 8px 15px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 20px;
            transition: var(--transicao);
        }

        .redes-sociais a:hover {
            background-color: var(--detalhe-escola);
            border-color: var(--detalhe-escola);
        }

        #resultado {
            border-left: 10px solid var(--sucesso);
        }
    </style>
</head>

<body>

    <nav class="menu">
        <div class="logo">EEB DOM JAIME</div>
        <div class="menu-centro">
            <span onclick="navegar('dashboard')">🏠 Início</span>
            <span onclick="navegar('alunos')">🎓 Alunos</span>
            <span onclick="navegar('professores')">👨‍🏫 Professores</span>
            <span onclick="navegar('funcionarios')">💼 Equipe</span>
        </div>
        <div style="cursor:pointer; font-size: 0.9rem; opacity: 0.8;" onclick="limparDados()">⚙️ Limpar Sistema</div>
    </nav>

    <div class="titulo-principal">
        <h1>Secretaria Escolar Digital</h1>
        <p>EEB Dom Jaime De Barros Câmara - Gestão 2026</p>
    </div>

    <div id="dashboard" class="card pagina-ativa">
        <h2 style="text-align: center;">Bem-vindo ao Portal de Registros</h2>
        <p style="text-align: center; color: #666;">Resumo estatístico da unidade de ensino:</p>

        <div class="grid-dashboard">
            <div class="item-dash">
                <h3>Estudantes</h3>
                <p id="cont-alunos">0</p>
            </div>
            <div class="item-dash">
                <h3>Corpo Docente</h3>
                <p id="cont-professores">0</p>
            </div>
            <div class="item-dash">
                <h3>Colaboradores</h3>
                <p id="cont-funcionarios">0</p>
            </div>
        </div>
    </div>

    <div id="alunos" class="card">
        <h2>🎓 Matrícula de Estudante</h2>
        <form>
            <label>Nome Completo do Aluno:</label>
            <input type="text" class="campo-nome" placeholder="Ex: Maria Silva Santos">
            <label>Documento (CPF):</label>
            <input type="text" class="campo-cpf" placeholder="000.000.000-00">
            <label>Série/Turma:</label>
            <select class="campo-turma-aluno">
                <option value="101">101 - 1º Ano Ensino Médio</option>
                <option value="201">201 - 2º Ano Ensino Médio</option>
                <option value="301">301 - 3º Ano Ensino Médio</option>
            </select>
            <button type="button" class="btn-cadastrar" onclick="registrar(this, 'alunos')">Confirmar Matrícula</button>
        </form>
    </div>

    <div id="professores" class="card">
        <h2>👨‍🏫 Cadastro de Professor</h2>
        <form>
            <label>Nome do Docente:</label>
            <input type="text" class="campo-nome">
            <label>Disciplina Principal:</label>
            <input type="text" class="campo-materia" placeholder="Ex: Geografia">
            <label>CPF:</label>
            <input type="text" class="campo-cpf">
            <button type="button" class="btn-cadastrar" onclick="registrar(this, 'professores')">Vincular
                Docente</button>
        </form>
    </div>

    <div id="funcionarios" class="card">
        <h2>💼 Cadastro de Colaborador</h2>
        <form>
            <label>Nome do Funcionário:</label>
            <input type="text" class="campo-nome">
            <label>Setor / Função:</label>
            <select class="campo-funcao">
                <option value="Administrativo">Administrativo</option>
                <option value="Alimentação Escolar">Alimentação Escolar</option>
                <option value="Manutenção">Manutenção</option>
                <option value="Biblioteca">Biblioteca</option>
            </select>
            <label>CPF:</label>
            <input type="text" class="campo-cpf">
            <button type="button" class="btn-cadastrar" onclick="registrar(this, 'funcionarios')">Registrar
                Colaborador</button>
        </form>
    </div>

    <div id="resultado" class="card"></div>

    <footer>
        <div>© 2026 EEB Dom Jaime de Barros Câmara - Sistema de Registro Interno</div>
        <div class="redes-sociais">
            <a href="https://www.instagram.com/eebdomjaime/" target="_blank">📸 Instagram</a>
            <a href="https://www.facebook.com/people/Dom-Jaime-De-Barros-C%C3%A2mara-Palho%C3%A7a/pfbid0hRWWHFhgkpLiLopQotCgV81GfRf4NMzAT84EcD96f1h9XghQzDfBrnXMFVw5LsE6l/?locale=pt_BR" target="_blank">📘 Facebook</a>
        </div>
    </footer>

    <script>
        function navegar(idPagina) {
            document.querySelectorAll('.card').forEach(card => card.classList.remove('pagina-ativa'));
            document.getElementById(idPagina).classList.add('pagina-ativa');
            document.getElementById('resultado').classList.remove('pagina-ativa');

            if (idPagina === 'dashboard') atualizarDashboard();
        }

        function atualizarDashboard() {
            document.getElementById('cont-alunos').innerText = localStorage.getItem('cont_alunos') || 0;
            document.getElementById('cont-professores').innerText = localStorage.getItem('cont_professores') || 0;
            document.getElementById('cont-funcionarios').innerText = localStorage.getItem('cont_funcionarios') || 0;
        }

        function registrar(botao, tipo) {
            const formulario = botao.closest('form');
            const nome = formulario.querySelector('.campo-nome').value;

            if (!nome) {
                alert("O preenchimento do nome é obrigatório.");
                return;
            }

            let chave = 'cont_' + tipo;
            let atual = parseInt(localStorage.getItem(chave) || 0);
            localStorage.setItem(chave, atual + 1);

            const resultadoDiv = document.getElementById("resultado");
            resultadoDiv.innerHTML = `
                <h2 style="color: var(--sucesso);">✓ Registro Realizado com Sucesso!</h2>
                <p>O profissional/estudante <strong>${nome}</strong> foi inserido no banco de dados da EEB Dom Jaime.</p>
            `;

            resultadoDiv.classList.add('pagina-ativa');
            resultadoDiv.scrollIntoView({ behavior: 'smooth' });

            botao.style.backgroundColor = "var(--sucesso)";
            botao.innerText = "Salvo!";

            setTimeout(() => {
                botao.style.backgroundColor = "";
                botao.innerText = "Confirmar Registro";
                formulario.reset();
                atualizarDashboard();
            }, 1500);
        }

        function limparDados() {
            if (confirm("ATENÇÃO: Isso apagará todos os registros do sistema escolar. Continuar?")) {
                localStorage.clear();
                atualizarDashboard();
                location.reload();
            }
        }

        window.onload = atualizarDashboard;
    </script>
</body>

</html>
