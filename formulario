<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal de Registro - EEB Dom Jaime</title>
    <style>
        :root {
            --azul-escuro: #16678d;
            --azul-claro: #add8e6;
            --branco-gelo: #f0ffff;
            --sucesso: #27ae60;
            --sombra: 0 8px 30px rgba(0, 0, 0, 0.1);
            --transicao: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        body {
            background-color: var(--azul-claro);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            color: #333;
        }

        .menu {
            background-color: var(--azul-escuro);
            color: white;
            padding: 0 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
            box-shadow: 0 2px 15px rgba(0, 0, 0, 0.2);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-weight: bold;
            font-size: 1.2rem;
        }

        .menu-centro span {
            margin: 0 10px;
            padding: 10px 15px;
            cursor: pointer;
            border-radius: 8px;
            transition: var(--transicao);
        }

        .menu-centro span:hover {
            background-color: rgba(255, 255, 255, 0.15);
        }

        .titulo-principal {
            text-align: center;
            color: var(--azul-escuro);
            margin: 40px 0;
            animation: slideDown 0.8s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card {
            background-color: var(--branco-gelo);
            width: 90%;
            max-width: 550px;
            padding: 35px;
            border-radius: 20px;
            margin: 20px auto;
            box-shadow: var(--sombra);
            display: none;
            /* Escondido por padrão */
        }

        .pagina-ativa {
            display: block;
            animation: scaleUp 0.5s ease forwards;
        }

        @keyframes scaleUp {
            from {
                opacity: 0;
                transform: scale(0.95);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        label {
            font-weight: 600;
            display: block;
            margin-bottom: 8px;
            color: #444;
        }

        input,
        select {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            box-sizing: border-box;
        }

        .btn-cadastrar {
            background-color: var(--azul-escuro);
            color: white;
            border: none;
            padding: 15px;
            border-radius: 10px;
            cursor: pointer;
            width: 100%;
            font-weight: bold;
            transition: var(--transicao);
        }

        .btn-cadastrar:hover {
            background-color: #0e4a68;
            transform: translateY(-3px);
        }

        #resultado {
            border-left: 8px solid var(--sucesso);
            background-color: #fafffa;
        }

        .card {

            background-color: #0e4a68;
            padding: 20px;
            border-radius: 4px;
            text-align: center;
            flex: 1;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-top: 20px;
            margin-bottom: 10px;
            
        }
        #dashboard{
            flex-direction: column;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;

        }
        
    </style>
</head>

<body>
    <nav class="menu">
        <div class="logo">PORTAL DOM JAIME</div>
        <div class="menu-centro">
            <span onclick="navegar('dashboard')">Dashboard</span>
            <span onclick="navegar('alunos')">Alunos</span>
            <span onclick="navegar('professores')">Professores</span>
            <span onclick="navegar('funcionarios')">Funcionários</span>
        </div>
        <div>Sair</div>
    </nav>

    <div class="titulo-principal">
        <h1>EEB Dom Jaime De Barros Câmara</h1>
        <p>Sistema Unificado de Registro Escolar</p>
    </div>
 <!-- Dashboard -->
    <div id="dashboard" class="card pagina-ativa">
        <h2>Dashboard</h2>
       
    </div>

    <!-- Alunos -->
    <div id="alunos" class="card">
        <h2>Registro de Novo Aluno</h2>
        <form>
            <label>Nome Completo:</label>
            <input type="text" class="campo-nome" placeholder="Digite o nome completo">

            <label>Data de Nascimento:</label>
            <input type="date" class="campo-data">

            <label>CPF:</label>
            <input type="text" class="campo-cpf" placeholder="000.000.000-00">

            <label>Turma do Aluno:</label>
            <select class="campo-turma-aluno">
                <option value="">Selecione a turma...</option>
                <option value="101 - Ensino Médio">101 - Ensino Médio</option>
                <option value="201 - Ensino Médio">201 - Ensino Médio</option>
                <option value="301 - Ensino Médio">301 - Ensino Médio</option>
                <option value="901 - Ensino Fundamental">901 - Ensino Fundamental</option>
            </select>

            <button type="button" class="btn-cadastrar" onclick="mostrarDados(this)">Concluir Registro</button>
        </form>
    </div>


    <!-- Professores -->
    <div id="professores" class="card">
        <h2>Registro de Docente</h2>
        <form>
            <label>Nome Completo:</label>
            <input type="text" class="campo-nome">
            <label>Matéria:</label>
            <input type="text" class="campo-materia">
            <label>Turmas:</label>
            <input type="text" class="campo-turmas">
            <label>CPF:</label>
            <input type="text" class="campo-cpf">
            <button type="button" class="btn-cadastrar" onclick="mostrarDados(this)">Vincular Professor</button>
        </form>
    </div>

    <!-- Funcionários -->
    <div id="funcionarios" class="card">
        <h2>Registro de Colaborador</h2>
        <form>
            <label>Nome Completo:</label>
            <input type="text" class="campo-nome">
            <label>Função:</label>
            <select class="campo-funcao">
                <option value="Faxineiro(a)">Faxineiro(a)</option>
                <option value="Cozinheiro(a)">Cozinheiro(a)</option>
                <option value="Supervisor(a)">Supervisor(a)</option>
            </select>
            <label>CPF:</label>
            <input type="text" class="campo-cpf">
            <button type="button" class="btn-cadastrar" onclick="mostrarDados(this)">Registrar Funcionário</button>
        </form>
    </div>

    <div id="resultado" class="card"></div>

    <script>
        function navegar(idPagina) {
            const cards = document.querySelectorAll('.card');
            cards.forEach(card => card.classList.remove('pagina-ativa'));
            document.getElementById(idPagina).classList.add('pagina-ativa');
            document.getElementById('resultado').classList.remove('pagina-ativa');
        }

        function mostrarDados(botao) {
            const formulario = botao.closest('form');

            // Coleta de dados genérica
            const nome = formulario.querySelector('.campo-nome')?.value || "Não informado";
            const cpf = formulario.querySelector('.campo-cpf')?.value || "Não informado";

            // Coleta de dados específicos (Aluno, Professor ou Funcionário)
            const turmaAluno = formulario.querySelector('.campo-turma-aluno')?.value;
            const materia = formulario.querySelector('.campo-materia')?.value;
            const turmasProf = formulario.querySelector('.campo-turmas')?.value;
            const funcao = formulario.querySelector('.campo-funcao')?.value;

            const resultadoDiv = document.getElementById("resultado");

            // Montagem do conteúdo do resultado
            let conteudo = `
            <h2 style="color: var(--sucesso);">✓ Registro Concluído!</h2>
            <p><strong>Nome:</strong> ${nome}</p>
            <p><strong>CPF:</strong> ${cpf}</p>
        `;

            if (turmaAluno) conteudo += `<p><strong>Turma Atual:</strong> ${turmaAluno}</p>`;
            if (materia) conteudo += `<p><strong>Matéria:</strong> ${materia}</p>`;
            if (turmasProf) conteudo += `<p><strong>Turmas que Leciona:</strong> ${turmasProf}</p>`;
            if (funcao) conteudo += `<p><strong>Função:</strong> ${funcao}</p>`;

            resultadoDiv.innerHTML = conteudo;

            // Exibe o card de resultado com animação
            resultadoDiv.classList.add('pagina-ativa');
            resultadoDiv.scrollIntoView({ behavior: 'smooth' });

            // Feedback visual no botão
            const corOriginal = botao.style.backgroundColor;
            botao.style.backgroundColor = "var(--sucesso)";
            botao.innerText = "Enviado!";

            setTimeout(() => {
                botao.style.backgroundColor = corOriginal;
                botao.innerText = "Registrar";
                formulario.reset();
            }, 2500);
        }
        function dashboard(){

            const qtdAlunos = localStorage.getItem('cont_alunos')||0;
            const qtdProfs = localStorage.getItem('cont_professores')||0;
            const qtdFuncs = localStorage.getItem('cont_funcionarios')||0;

            const cards = document.querySelectAll("#dashboard .card p");

            card[0].innerText = qtdAlunos;
            card[1].innerText = qtdProfs;
            card[2].innerText = qtdFuncs;
        }

    </script>

</body>

</html>
